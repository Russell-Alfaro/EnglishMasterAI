@page "/register"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Registro — EnglishMasterAI</PageTitle>

<div class="register-page">
    <div class="register-card">
        <div class="register-header">
            <div class="logo">🌟</div>
            <h1 class="brand-title">EnglishMasterAI</h1>
            <p class="brand-subtitle">Aprende inglés con Inteligencia Artificial</p>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger alert-dismissible d-flex align-items-center" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <div>@_errorMessage</div>
                <button type="button" class="btn-close ms-auto" aria-label="Cerrar"
                        @onclick="() => _errorMessage = string.Empty"></button>
            </div>
        }

        @if (_step == Step.Submitted)
        {
            <div class="text-center">
                <div style="font-size: 3rem;">⏳</div>
                <h3 class="mb-3">¡Comprobante recibido!</h3>
                <p class="text-muted mb-4">
                    Tu solicitud de registro para el nivel <strong>@_model.InitialLevel</strong>
                    está <strong>pendiente de verificación</strong>. Un administrador revisará tu
                    comprobante de pago y activará tu cuenta pronto.
                </p>
                <a href="/" class="btn-primary" style="display:inline-block; text-decoration:none; text-align:center;">
                    Volver al inicio
                </a>
            </div>
        }
        else if (_step == Step.Payment)
        {
            <div class="text-center mb-3">
                <h3 class="mb-2">💳 Completa tu inscripción</h3>
                <p class="text-muted">Nivel elegido: <strong>@_model.InitialLevel</strong></p>
                <div style="font-size: 2rem; font-weight: 800; color: var(--color-accent-gold);">
                    S/ @_price.ToString("0.00")
                </div>
            </div>

            <div class="text-center mb-3">
                <img src="/images/yape-qr.png" alt="QR de Yape"
                     style="max-width: 220px; width: 100%; border-radius: 12px; border: 1px solid var(--color-border);" />
                <p class="text-muted small mt-2">
                    Escanea el QR con Yape, paga <strong>S/ @_price.ToString("0.00")</strong>,
                    y sube la captura de tu comprobante abajo.
                </p>
            </div>

            <div class="form-group">
                <label>Comprobante de pago (imagen)</label>
                <InputFile OnChange="HandleFileSelected" accept="image/*" class="form-input" />
                @if (_selectedFileName is not null)
                {
                    <p class="text-muted small mt-1">📎 @_selectedFileName</p>
                }
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="button" class="btn-primary" style="background: rgba(255,255,255,0.08);"
                        @onclick="() => _step = Step.Form" disabled="@_isLoading">
                    ← Volver
                </button>
                <button type="button" class="btn-primary" @onclick="SubmitRegistration"
                        disabled="@(_isLoading || _receiptBytes is null)">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Enviando...</span>
                    }
                    else
                    {
                        <span>Enviar comprobante</span>
                    }
                </button>
            </div>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="GoToPayment" class="register-form">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label for="fullName">Nombre Completo</label>
                    <div class="input-wrapper">
                        <span class="input-icon">👤</span>
                        <InputText id="fullName" @bind-Value="_model.FullName" class="form-input"
                                   placeholder="Ej: Ana García López" />
                    </div>
                    <ValidationMessage For="@(() => _model.FullName)" class="validation-msg" />
                </div>

                <div class="form-group">
                    <label for="email">Correo Electrónico</label>
                    <div class="input-wrapper">
                        <span class="input-icon">📧</span>
                        <InputText id="email" @bind-Value="_model.Email" class="form-input"
                                   placeholder="tu@correo.com" />
                    </div>
                    <ValidationMessage For="@(() => _model.Email)" class="validation-msg" />
                </div>

                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <div class="input-wrapper">
                        <span class="input-icon">🔒</span>
                        <InputText id="password" type="password" @bind-Value="_model.Password" class="form-input"
                                   placeholder="Mínimo 8 caracteres" />
                    </div>
                    <ValidationMessage For="@(() => _model.Password)" class="validation-msg" />
                </div>

                <div class="form-group">
                    <label for="nativeLanguage">Idioma Nativo</label>
                    <div class="input-wrapper">
                        <span class="input-icon">🌍</span>
                        <InputSelect id="nativeLanguage" @bind-Value="_model.NativeLanguage" class="form-input form-select">
                            <option value="Spanish">Español</option>
                            <option value="Portuguese">Portugués</option>
                            <option value="French">Francés</option>
                            <option value="German">Alemán</option>
                            <option value="Italian">Italiano</option>
                        </InputSelect>
                    </div>
                </div>

                <div class="form-group">
                    <label for="initialLevel">Nivel de Inglés Inicial</label>
                    <div class="input-wrapper">
                        <span class="input-icon">🎓</span>
                        <InputSelect id="initialLevel" @bind-Value="_model.InitialLevel" class="form-input form-select">
                            <option value="A1">A1 - Principiante (S/ 100)</option>
                            <option value="A2">A2 - Básico (S/ 120)</option>
                            <option value="B1">B1 - Intermedio (S/ 140)</option>
                            <option value="B2">B2 - Intermedio Alto (S/ 160)</option>
                            <option value="C1">C1 - Avanzado (S/ 180)</option>
                            <option value="C2">C2 - Maestría (S/ 200)</option>
                        </InputSelect>
                    </div>
                </div>

                <button type="submit" class="btn-primary" disabled="@_isLoading" id="btn-register">
                    <i class="bi bi-credit-card-fill me-2"></i>
                    <span>Continuar con el pago</span>
                </button>
            </EditForm>

            <p class="login-link">
                ¿Ya tienes cuenta?
                <a href="/">Inicia sesión aquí</a>
            </p>
        }
    </div>
</div>

@code {
    private enum Step { Form, Payment, Submitted }
    private Step _step = Step.Form;

    private readonly RegisterModel _model = new();
    private bool _isLoading = false;
    private string _errorMessage = string.Empty;

    private decimal _price;
    private byte[]? _receiptBytes;
    private string? _receiptContentType;
    private string? _selectedFileName;

    private async Task GoToPayment()
    {
        _errorMessage = string.Empty;
        try
        {
            _price = await Http.GetFromJsonAsync<decimal>($"api/registrations/price/{_model.InitialLevel}");
            _step = Step.Payment;
        }
        catch (Exception)
        {
            _errorMessage = "No se pudo obtener el precio. Verifica tu conexión.";
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = string.Empty;
        var file = e.File;

        const long maxSizeBytes = 2 * 1024 * 1024;
        if (file.Size > maxSizeBytes)
        {
            _errorMessage = "La imagen no debe superar 2 MB.";
            _receiptBytes = null;
            _selectedFileName = null;
            return;
        }

        using var stream = file.OpenReadStream(maxSizeBytes);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        _receiptBytes = memoryStream.ToArray();
        _receiptContentType = file.ContentType;
        _selectedFileName = file.Name;
    }

    private async Task SubmitRegistration()
    {
        if (_receiptBytes is null)
        {
            _errorMessage = "Debes subir la imagen del comprobante.";
            return;
        }

        _isLoading = true;
        _errorMessage = string.Empty;

        try
        {
            var command = new
            {
                fullName            = _model.FullName,
                email               = _model.Email,
                password            = _model.Password,
                nativeLanguage      = _model.NativeLanguage,
                initialLevel        = _model.InitialLevel,
                receiptImageBase64  = Convert.ToBase64String(_receiptBytes),
                receiptContentType  = _receiptContentType ?? "image/png"
            };

            var response = await Http.PostAsJsonAsync("api/registrations", command);

            if (response.IsSuccessStatusCode)
            {
                _step = Step.Submitted;
            }
            else
            {
                string rawBody = await response.Content.ReadAsStringAsync();
                _errorMessage = TryExtractApiMessage(rawBody, (int)response.StatusCode);
            }
        }
        catch (HttpRequestException)
        {
            _errorMessage = "No se pudo conectar con el servidor. Verifica tu conexión o que la API esté en ejecución.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string TryExtractApiMessage(string rawBody, int statusCode)
    {
        if (string.IsNullOrWhiteSpace(rawBody))
            return statusCode switch
            {
                409 => "Este correo ya está registrado o tiene una solicitud pendiente.",
                400 => "Los datos enviados no son válidos.",
                500 => "Error interno del servidor. Intenta más tarde.",
                _   => $"Error {statusCode}. Por favor intenta de nuevo."
            };

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(rawBody);
            var root = doc.RootElement;

            foreach (var field in new[] { "message", "Message", "title", "Title", "detail", "Detail" })
            {
                if (root.TryGetProperty(field, out var prop) &&
                    prop.ValueKind == System.Text.Json.JsonValueKind.String)
                {
                    var val = prop.GetString();
                    if (!string.IsNullOrWhiteSpace(val)) return val!;
                }
            }

            return rawBody.Length <= 200 ? rawBody : rawBody[..200] + "...";
        }
        catch
        {
            return rawBody.Length <= 200 ? rawBody : rawBody[..200] + "...";
        }
    }

    public class RegisterModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "El nombre es obligatorio")]
        [System.ComponentModel.DataAnnotations.MinLength(3, ErrorMessage = "Mínimo 3 caracteres")]
        public string FullName { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "El correo es obligatorio")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Correo inválido")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "La contraseña es obligatoria")]
        [System.ComponentModel.DataAnnotations.MinLength(8, ErrorMessage = "Mínimo 8 caracteres")]
        public string Password { get; set; } = string.Empty;

        public string NativeLanguage { get; set; } = "Spanish";

        public string InitialLevel { get; set; } = "A1";
    }
}